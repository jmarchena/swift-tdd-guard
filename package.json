{
  "name": "swift-tdd-guard",
  "version": "0.1.0",
  "description": "TDD enforcement for Swift development with Claude Code",
  "type": "module",
  "bin": {
    "swift-tdd-guard": "dist/cli/tdd-guard.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "checks": "tsc --noEmit && vitest run"
  },
  "keywords": ["tdd", "swift", "claude-code", "testing", "xcode"],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
